export GRAALVM_HOME="/Library/Java/JavaVirtualMachines/graalvm-jdk-23.0.1+11.1/Contents/Home"
export JAVA_HOME=$GRAALVM_HOME
export KAFKA_HOME="./lib/kafka"
export CLASSPATH="$KAFKA_HOME/libs/*:src/main/resources:bin"
export PATH="$GRAALVM_HOME/bin:$KAFKA_HOME/bin:$PATH"
export KAFKA_TOPIC=libnjkafka-build-topic
export KAFKA_BROKERS=localhost:9092
export BUNDLE_EXEC="chruby-exec ruby-4.0 -- bundle exec"
